// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------------------
// Modelos da Loja e Jogadores
// -------------------------------------------------------------

// Product model removed - products are managed in src/lib/catalog.ts for MVP

model Order {
  id              String   @id @default(cuid())
  paymentId       String?  @unique
  playerNick      String   // Nick do Minecraft digitado
  playerUuid      String   // UUID oficial da Mojang
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, COMPLETED, REFUNDED, CANCELED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           OrderItem[]
  commandQueue    CommandQueue[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  price     Float
  quantity  Int     @default(1)
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CommandQueue {
  id         String   @id @default(cuid())
  orderId    String
  command    String   // Comando ja formatado com o nick correto
  status     String   @default("PENDING") // PENDING, EXECUTED
  createdAt  DateTime @default(now())
  executedAt DateTime?
  
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------
// Atualizações do Servidor
// -------------------------------------------------------------

model Update {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------------------------------------------------
// Sugestões / Enquetes da Comunidade
// -------------------------------------------------------------

model Suggestion {
  id          String             @id @default(cuid())
  title       String
  description String?
  type        String             @default("updown") // "updown" ou "poll"
  status      String             @default("open")   // open, reviewing, approved, rejected, cancelled, implemented
  options     SuggestionOption[]
  votes       SuggestionVote[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model SuggestionOption {
  id           String           @id @default(cuid())
  suggestionId String
  suggestion   Suggestion       @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  label        String
  order        Int              @default(0)
  votes        SuggestionVote[]
}

model SuggestionVote {
  id           String            @id @default(cuid())
  suggestionId String
  suggestion   Suggestion        @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  optionId     String?
  option       SuggestionOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voteType     String?           // "up" ou "down" (apenas para tipo updown)
  playerNick   String
  playerUuid   String
  createdAt    DateTime          @default(now())

  @@unique([suggestionId, playerUuid])
}
